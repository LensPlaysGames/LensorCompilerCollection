#ifndef LCC_DRIVER_VERSION_HH
#define LCC_DRIVER_VERSION_HH

#define LCC_VERSION_MAJOR     @CMAKE_PROJECT_VERSION_MAJOR @
#define LCC_VERSION_MINOR     @CMAKE_PROJECT_VERSION_MINOR @
#define LCC_VERSION_PATCH     @CMAKE_PROJECT_VERSION_PATCH @
#define LCC_VERSION_STRING    "@CMAKE_PROJECT_VERSION@"
#define LCC_BUILD_DATE_STRING "@BUILD_DATE@"
#define LCC_IDENT             "LCC: " LCC_VERSION_STRING " " LCC_BUILD_DATE_STRING

#endif /* LCC_DRIVER_VERSION_HH */
